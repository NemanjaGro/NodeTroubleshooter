<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\justlogo.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NodeTroubleshooter\NodeTroubleshooter.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\NodeTroubleshooter\Data\nodespecs.json" Link="Data\nodespecs.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\logo.png" />
    <Resource Include="Assets\justlogo.png" />
    <Resource Include="Assets\justlogo.ico" />
  </ItemGroup>

</Project>
